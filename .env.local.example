# ===========================================
# ParkPro Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your API keys
#
# cp .env.local.example .env.local

# Mapbox (https://account.mapbox.com/access-tokens/)
# Sign up free at mapbox.com - 50,000 free map loads/month
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# OpenWeatherMap (https://home.openweathermap.org/api_keys)
# Free tier: 1,000 calls/day
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# National Park Service API (https://www.nps.gov/subjects/developer/get-started.htm)
# Free - just register for a key
NPS_API_KEY=your_nps_api_key_here

# Recreation.gov API (https://ridb.recreation.gov/docs)
# Free - register at ridb.recreation.gov
RECREATION_GOV_API_KEY=your_recreation_gov_key_here

# Google Popular Times / BestTime.app (https://besttime.app/)
# Low-cost alternative for busyness data (~$30/mo budget)
# If not available, the app falls back to historical estimates
BESTTIME_API_KEY=your_besttime_api_key_here
